* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

.html {
  font-size: 62.5%;
}

.header {
  background-color: #f0e7d6;
  justify-content: space-between;
  width: 100%;
  margin-bottom: 1.5rem;
  padding: 1.5rem 4rem;
  display: flex;
}

.header h1 {
  font-family: Verdana, Geneva, Tahoma, sans-serif;
}

.header ul {
  gap: 40px;
  display: flex;
}

.header ul li {
  list-style: none;
}

.header ul li button {
  background-color: #9dbdb8;
  border: none;
  border-radius: 10px;
  padding: 1rem;
  font-size: 1rem;
  font-weight: 550;
  display: flex;
}

.users-data {
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 2rem;
  padding: 1rem 2rem;
  display: grid;
}

.user {
  text-transform: capitalize;
  background-color: #f0e7d6;
  border-radius: 2rem;
  padding: 2rem;
  font-family: Segoe UI, Tahoma, Geneva, Verdana, sans-serif;
}

.user img {
  justify-self: center;
  width: 50px;
  height: 50px;
}

.user h2 {
  font-size: 1.45rem;
}

.user p {
  font-size: 1.125rem;
}
